# ==========================================================
# Meeple Cafe AI Ordering Chatbot
# Environment Variables
# ==========================================================

# ----------------------------------------------------------
# FastAPI
# ----------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ----------------------------------------------------------
# API
# ----------------------------------------------------------
API_TITLE=Meeple Cafe AI Ordering Chatbot
API_VERSION=3.0.0

# ----------------------------------------------------------
# Restaurant Information
# ----------------------------------------------------------
RESTAURANT_NAME=Meeple Cafe
RESTAURANT_PHONE=+91-9876543210
RESTAURANT_EMAIL=support@meeplecafe.com
RESTAURANT_ADDRESS=Chennai, Tamil Nadu
OPENING_HOURS=09:00 AM - 10:00 PM

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
DATABASE_PATH=data/orders.db

# ----------------------------------------------------------
# Menu Data
# ----------------------------------------------------------
MENU_CSV=data/menu.csv
FAQ_CSV=data/faq.csv
RESTAURANT_CSV=data/restaurant.csv

# ----------------------------------------------------------
# Vector Database
# ----------------------------------------------------------
FAISS_INDEX=vector_db/menu.index
FAISS_METADATA=vector_db/metadata.pkl

# ----------------------------------------------------------
# Embedding Model
# ----------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----------------------------------------------------------
# Retrieval
# ----------------------------------------------------------
TOP_K=5
SIMILARITY_THRESHOLD=0.35

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
